# =============================================
# AIプロバイダー選択
# anthropic / openai / gemini のどれかを入力
# =============================================
PROVIDER=gemini

# ── Anthropic (Claude) ──
# 取得先: https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── OpenAI (GPT) ──
# 取得先: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Google Gemini ← 無料枠あり・おすすめ ──
# 取得先: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
